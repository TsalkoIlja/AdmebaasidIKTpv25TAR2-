----3. TABEL LOOM


CREATE TABLE Loom (
    loom_id INT PRIMARY KEY IDENTITY(1,1),
    nimi VARCHAR(50) NOT NULL,
    liik VARCHAR(50) NOT NULL,
    tõug VARCHAR(50),
    sugu VARCHAR(10) CHECK (sugu IN ('Isane','Emane')),
    saabumise_kuupaev DATE DEFAULT GETDATE(),
    boks_id INT NOT NULL,

    CONSTRAINT fk_loom_boks
    FOREIGN KEY (boks_id) REFERENCES Boks(boks_id)
);

