--7. STORED PROCEDURES (3 tk)


-- 1. Lisa uus loom
CREATE PROCEDURE lisaLoom
@nimi VARCHAR(50),
@liik VARCHAR(50),
@boks_id INT
AS
BEGIN
    INSERT INTO Loom (nimi, liik, boks_id)
    VALUES (@nimi, @liik, @boks_id);

    SELECT * FROM Loom;
END;
GO


-- 2. Kustuta loom
CREATE PROCEDURE kustutaLoom
@id INT
AS
BEGIN
    DELETE FROM Loom
    WHERE loom_id = @id;

    SELECT * FROM Loom;
END;
GO


-- 3. Otsi loom nime järgi
CREATE PROCEDURE otsiLoom
@taht CHAR(1)
AS
BEGIN
    SELECT * FROM Loom
    WHERE nimi LIKE @taht + '%';
END;
GO


